APP_NAME=IspManager
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000
APP_TIMEZONE=Europe/Rome
APP_LOCALE=it
APP_FALLBACK_LOCALE=it

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Carrier mock (IMPORTANTE: true in dev per non consumare quote reali)
CARRIER_MOCK=true
CARRIER_OF_ENVIRONMENT=test
CARRIER_FC_ENVIRONMENT=test

# Telescope (dev only)
TELESCOPE_ENABLED=true


# PostgreSQL + PostGIS
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ispmanager
DB_USERNAME=ispmanager
DB_PASSWORD=secret
DB_SCHEMA=public

# Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# Cache
CACHE_STORE=redis
CACHE_PREFIX=ispmanager_

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true

# Queue
QUEUE_CONNECTION=redis

# Broadcasting
BROADCAST_CONNECTION=log

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ispmanager.it"
MAIL_FROM_NAME="${APP_NAME}"

# MinIO (S3-compatible)
AWS_ACCESS_KEY_ID=ispmanager
AWS_SECRET_ACCESS_KEY=secret123456
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=ispmanager-documents
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ACCESS_KEY=ispmanager
MINIO_SECRET_KEY=secret123456
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Laravel Octane
OCTANE_SERVER=swoole

# Laravel Horizon
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# Carrier API - Open Fiber
OF_WSDL_URL=
OF_TOKEN_ID=
OF_CODICE_OPERATORE=
OF_LINE_TESTING_BASE_URL=https://api.openfiber.it/linetesting/v1
OF_DAILY_QUOTA_LIMIT=500
OF_SOAP_ENDPOINT=

# Carrier API - FiberCop
FC_API_BASE_URL=https://api.fibercop.it/ngasp/v1
FC_CLIENT_KEY=
FC_CLIENT_SECRET=
FC_OAUTH_TOKEN_URL=https://api.fibercop.it/oauth/token
FC_DAILY_QUOTA_LIMIT=1000
FC_NETMAP_SFTP_HOST=
FC_NETMAP_SFTP_USER=
FC_NETMAP_SFTP_PASSWORD=
FC_NETMAP_SFTP_PATH=/netmap/

# Carrier API - Fastweb
FW_API_BASE_URL=
FW_CLIENT_KEY=
FW_CLIENT_SECRET=
FW_DAILY_QUOTA_LIMIT=300

# API Quota Manager thresholds
API_QUOTA_WARNING_THRESHOLD=0.80
API_QUOTA_BLOCK_THRESHOLD=0.95

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# FatturaPA / SDI
SDI_CODICE_DESTINATARIO=0000000
SDI_PEC=
SDI_TRASMITTENTE_ID_PAESE=IT
SDI_TRASMITTENTE_CODICE=

# Azienda emittente fatture
COMPANY_RAGIONE_SOCIALE=
COMPANY_PIVA=
COMPANY_CF=
COMPANY_REA=
COMPANY_INDIRIZZO=
COMPANY_CAP=
COMPANY_CITTA=
COMPANY_PROVINCIA=
COMPANY_PAESE=IT
COMPANY_TELEFONO=
COMPANY_EMAIL=
COMPANY_PEC=
COMPANY_IBAN=

# SEPA SDD
SEPA_CREDITOR_ID=
SEPA_BIC=
SEPA_IBAN=

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_DEFAULT_TENANT_ID=

# Twilio (SMS / WhatsApp fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_DEFAULT_TENANT_ID=

# AI Module (Anthropic Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001

# GenieACS (TR-069 ACS)
GENIEACS_BASE_URL=http://localhost:7557
GENIEACS_USERNAME=admin
GENIEACS_PASSWORD=admin

# RADIUS / FreeRADIUS CoA (RFC 5176)
RADIUS_COA_SECRET=testing123
RADIUS_COA_PORT=3799
RADIUS_COA_TIMEOUT=5

# Walled Garden (captive portal per utenti morosi)
WALLED_GARDEN_URL=https://paga.isp.local
WALLED_GARDEN_TOKEN_TTL=72
WALLED_GARDEN_DL_KBPS=128
WALLED_GARDEN_UL_KBPS=128
RADIUS_RETENTION_YEARS=6

# SNMP Poller
SNMP_COMMUNITY=public
SNMP_TIMEOUT_MS=2000
SNMP_RETRIES=2
SNMP_POLL_INTERVAL=300

# Spatie Activitylog
ACTIVITY_LOGGER_ENABLED=true

# Coverage cache TTL (seconds)
COVERAGE_ADDRESS_CACHE_TTL=604800
LINE_TEST_CACHE_TTL=21600
ORDER_STATUS_CACHE_TTL=14400
